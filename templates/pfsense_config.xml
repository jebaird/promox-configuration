<?xml version="1.0"?>
<pfsense>
    <version>24.03</version>
    <revision>
        <time>{{TIMESTAMP}}</time>
        <description>Auto-generated by proxmox-config wizard</description>
    </revision>
    <system>
        <hostname>{{HOSTNAME}}</hostname>
        <domain>{{DOMAIN}}</domain>
        <timezone>Etc/UTC</timezone>
        <language>en_US</language>
        <dnsserver>{{DNS_SERVERS}}</dnsserver>
        <dnsallowoverride>1</dnsallowoverride>
        <group>
            <name>admins</name>
            <description>System Administrators</description>
            <scope>system</scope>
            <gid>110</gid>
            <member>0</member>
            <priv>page-all</priv>
        </group>
        <user>
            <name>admin</name>
            <descr>System Administrator</descr>
            <scope>system</scope>
            <groupname>admins</groupname>
            <password>{{ADMIN_PASSWORD_HASH}}</password>
            <uid>0</uid>
            <priv>user-shell-access</priv>
        </user>
        <nextuid>2000</nextuid>
        <nextgid>2000</nextgid>
        <webgui>
            <protocol>https</protocol>
            <loginautocomplete>1</loginautocomplete>
            <althostnames></althostnames>
        </webgui>
        <disablefilter>0</disablefilter>
        <optimization>normal</optimization>
        <enablesshd>{{SSH_ENABLED}}</enablesshd>
        <sshport>22</sshport>
    </system>
    <interfaces>
        <wan>
            <enable>1</enable>
            <if>vtnet0</if>
            <descr>WAN</descr>
            <ipaddr>dhcp</ipaddr>
            <ipaddrv6>dhcp6</ipaddrv6>
            <dhcphostname></dhcphostname>
            <alias-address></alias-address>
            <alias-subnet>32</alias-subnet>
            <dhcprejectfrom></dhcprejectfrom>
            <gateway></gateway>
            <blockpriv>1</blockpriv>
            <blockbogons>1</blockbogons>
        </wan>
        <lan>
            <enable>1</enable>
            <if>vtnet1</if>
            <descr>LAN</descr>
            <ipaddr>{{LAN_IP}}</ipaddr>
            <subnet>{{LAN_SUBNET}}</subnet>
            <gateway></gateway>
            <media></media>
            <mediaopt></mediaopt>
        </lan>
    </interfaces>
    <gateways>
        <gateway_item>
            <interface>wan</interface>
            <gateway>dynamic</gateway>
            <name>WAN_DHCP</name>
            <weight>1</weight>
            <ipprotocol>inet</ipprotocol>
            <descr>Interface WAN Gateway</descr>
            <defaultgw>1</defaultgw>
        </gateway_item>
    </gateways>
    <staticroutes></staticroutes>
    <dhcpd>
        <lan>
            <enable>1</enable>
            <range>
                <from>{{DHCP_START}}</from>
                <to>{{DHCP_END}}</to>
            </range>
            <defaultleasetime>7200</defaultleasetime>
            <maxleasetime>86400</maxleasetime>
            <gateway>{{LAN_IP}}</gateway>
            <dnsserver>{{LAN_IP}}</dnsserver>
            <domain>{{DOMAIN}}</domain>
            <domainsearchlist>{{DOMAIN}}</domainsearchlist>
            <ddnsdomain>{{DOMAIN}}</ddnsdomain>
            <ddnsdomainprimary>{{LAN_IP}}</ddnsdomainprimary>
            <ddnsdomainkeyname></ddnsdomainkeyname>
            <ddnsdomainkey></ddnsdomainkey>
{{DHCP_STATIC_MAPPINGS}}
        </lan>
    </dhcpd>
    <dhcpdv6></dhcpdv6>
    <unbound>
        <enable>1</enable>
        <dnssec>1</dnssec>
        <active_interface>lan</active_interface>
        <outgoing_interface>wan</outgoing_interface>
        <system_domain_local_zone_type>transparent</system_domain_local_zone_type>
        <regdhcp>1</regdhcp>
        <regdhcpdomain>{{DOMAIN}}</regdhcpdomain>
        <regdhcpstatic>1</regdhcpstatic>
        <forwarding>{{DNS_FORWARDING_ENABLED}}</forwarding>
        <forward_tls_upstream>{{DNS_FORWARD_TLS}}</forward_tls_upstream>
        <custom_options></custom_options>
{{DNS_HOST_OVERRIDES}}
{{DNS_DOMAIN_OVERRIDES}}
    </unbound>
    <nat>
        <outbound>
            <mode>automatic</mode>
        </outbound>
    </nat>
    <filter>
        <rule>
            <id></id>
            <tracker>{{RULE_TRACKER_1}}</tracker>
            <type>pass</type>
            <interface>lan</interface>
            <ipprotocol>inet</ipprotocol>
            <tag></tag>
            <tagged></tagged>
            <max></max>
            <max-src-nodes></max-src-nodes>
            <max-src-conn></max-src-conn>
            <max-src-states></max-src-states>
            <statetimeout></statetimeout>
            <statetype>keep state</statetype>
            <os></os>
            <source>
                <network>lan</network>
            </source>
            <destination>
                <any>1</any>
            </destination>
            <descr>Default allow LAN to any rule</descr>
        </rule>
        <rule>
            <id></id>
            <tracker>{{RULE_TRACKER_2}}</tracker>
            <type>pass</type>
            <interface>lan</interface>
            <ipprotocol>inet6</ipprotocol>
            <tag></tag>
            <tagged></tagged>
            <max></max>
            <max-src-nodes></max-src-nodes>
            <max-src-conn></max-src-conn>
            <max-src-states></max-src-states>
            <statetimeout></statetimeout>
            <statetype>keep state</statetype>
            <os></os>
            <source>
                <network>lan</network>
            </source>
            <destination>
                <any>1</any>
            </destination>
            <descr>Default allow LAN IPv6 to any rule</descr>
        </rule>
    </filter>
    <shaper></shaper>
    <ipsec></ipsec>
    <aliases></aliases>
    <proxyarp></proxyarp>
    <ppps></ppps>
    <vlans></vlans>
    <wireless></wireless>
    <bridges></bridges>
    <laggs></laggs>
    <gifs></gifs>
    <qinqs></qinqs>
    <virtualip></virtualip>
    <dyndnses></dyndnses>
    <dnsupdates></dnsupdates>
    <syslog>
        <filterdescriptions>1</filterdescriptions>
    </syslog>
    <captiveportal></captiveportal>
    <installedpackages></installedpackages>
</pfsense>
