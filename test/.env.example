# Test Instance Configuration
# ============================
# This file overrides values from the base .env file.
# Layering: .env (base) → test/.env (overrides)
#
# Base credentials (Cloudflare, domain, etc.) come from ../.env
# Only test-specific connection settings are defined here.

# Proxmox Connection
# ==================
# Override to point at the local QEMU-in-Docker test instance.
# The VM runs at 172.30.0.2 inside the container's network.
PROXMOX_HOST=172.30.0.2
# PROXMOX_PORT=8006
PROXMOX_NODE=pve

# Proxmox Root Password
# =====================
# Used by .\proxmox-test.ps1 tunnel to forward ports via SSH.
# Set this to avoid entering password each time.
PROXMOX_ROOT_PASSWORD=

# Test Instance API Token
# =======================
# Created after Proxmox installation completes.
# Run: .\proxmox-test.ps1 setup
PROXMOX_TOKEN_ID=root@pam!test
PROXMOX_TOKEN_SECRET=<replace-after-install>
