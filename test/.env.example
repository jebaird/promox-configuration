# Test Instance Credentials
# =========================
# After completing the Proxmox VE installer inside the QEMU container, create an
# API token and fill in the values below.
#
# Default installer credentials:
#   Web UI: http://localhost:8006 (noVNC viewer)
#   Username: root
#   Password: (set during installation)
#
# Create an API token:
#   Datacenter → Permissions → API Tokens → Add
#   User: root@pam
#   Token ID: test
#   Privilege Separation: unchecked (for full access in testing)

PROXMOX_TOKEN_ID=root@pam!test
PROXMOX_TOKEN_SECRET=<replace-after-install>

# Connection settings
# ===================
# Default: QEMU VM's internal IP (fixed by qemux/qemu image)
# Change these to test against a different Proxmox server:
PROXMOX_HOST=172.30.0.2
# PROXMOX_PORT=8006
# PROXMOX_NODE=pve
