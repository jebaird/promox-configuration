# Proxmox Host Configuration
PROXMOX_HOST=10.0.0.3
# PROXMOX_PORT=8006
# PROXMOX_NODE=pve

# Proxmox API Token Authentication
# Create token in Proxmox UI: Datacenter -> Permissions -> API Tokens
# Format: user@realm!tokenid
PROXMOX_TOKEN_ID=root@pam!automation
PROXMOX_TOKEN_SECRET=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Optional: Path to CA certificate for SSL verification
# PROXMOX_CA_CERT=/path/to/proxmox-ca.pem

# pfSense Network Configuration
# These set defaults for the wizard - can be overridden interactively
# PFSENSE_DOMAIN=local
# PFSENSE_LAN_SUBNET=10.0.0

# Cloudflare DNS Challenge for SSL Certificates
# Required for cert-manager deployment
# Create a scoped API token at: https://dash.cloudflare.com/profile/api-tokens
# Token needs: Zone:DNS:Edit permission on your zone
# CLOUDFLARE_API_TOKEN=xxxxx
# CLOUDFLARE_ZONE=example.com
